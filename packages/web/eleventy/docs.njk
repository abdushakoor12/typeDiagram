---
layout: base.njk
pagination:
  data: docs
  size: 1
  alias: doc
permalink: "/docs/{{ doc.slug }}.html"
eleventyComputed:
  title: "{{ doc.title }} — typeDiagram"
  description: "{{ doc.title }} — typeDiagram documentation. Language-neutral DSL for describing algebraic data types and generating code in TypeScript, Python, Rust, Go, and C#."
  structuredData:
    "@context": "https://schema.org"
    "@type": "TechArticle"
    headline: "{{ doc.title }}"
    description: "{{ doc.title }} — typeDiagram documentation."
    url: "https://typediagram.dev/docs/{{ doc.slug }}.html"
    inLanguage: "en"
stylesHref: /src/styles.css
navLogoLink: /
navPlaygroundHref: /#playground
navConverterHref: /converter.html
navDocsHref: /docs/
navBlogHref: /blog/
---
<div class="docs-layout">
  <aside class="docs-sidebar">
    {% set activeSlug = doc.slug %}
    {% include "docs-nav-groups.njk" %}
  </aside>
  <nav class="docs-mobile-nav" aria-label="Documentation sections">
    {% set activeSlug = doc.slug %}
    {% include "docs-nav-groups.njk" %}
  </nav>
  <main class="docs-content">
    {{ doc.html | safe }}
  </main>
</div>
